{
  "name": "@kartoffel/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:lib": "npm run dev --workspace=packages/ui-library",
    "dev:app": "npm run dev --workspace=apps/kartoffel-web",
    "build:app": "npm run build --workspace=apps/kartoffel-web",
    "storybook": "npm run storybook --workspace=packages/ui-library",
    "build:lib": "npm run build --workspace=packages/ui-library",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "parse": "npm run parse --workspace=@kartoffel/burgertest-pipeline --",
    "parse:debug": "npm run debug --workspace=@kartoffel/burgertest-pipeline",
    "merge": "npm run merge --workspace=@kartoffel/burgertest-pipeline",
    "verify": "npm run verify --workspace=@kartoffel/burgertest-pipeline",
    "translate": "npm run translate --workspace=@kartoffel/burgertest-pipeline",
    "enrich": "npm run enrich --workspace=@kartoffel/burgertest-pipeline",
    "bundle": "npm run bundle --workspace=@kartoffel/burgertest-pipeline",
    "pipeline": "npm run pipeline --workspace=@kartoffel/burgertest-pipeline"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.6",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
